ENV=prod
DEBUG=false
SECRET_KEY=please-change-to-a-long-random-string

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/sfa
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# ERP
ERP_BASE_URL=https://erp.example.com/api
ERP_API_KEY=
ERP_SYNC_CRON_MINUTES=30

# Mail (SMTP fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=procurement@example.com

# Gmail / Graph
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rules
NO_REPLY_DAYS_THRESHOLD=3
RED_AI_AFTER_DAYS=2

# ── Mail automation (safe defaults: everything OFF) ───────────────────────
SCHEDULER_ENABLED=false
MAIL_INBOX_ENABLED=false
SMTP_ENABLED=false

# IMAP (incoming supplier replies)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Cron intervals (minutes)
MAIL_FETCH_INTERVAL_MINUTES=10
STATUS_CHANGE_INTERVAL_MINUTES=30
AUTO_REPLY_INTERVAL_MINUTES=15
MAIL_SEND_INTERVAL_MINUTES=5
