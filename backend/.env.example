APP_NAME=Supplier Follow-up Agent
DEBUG=true

# Local dev defaults: SQLite (no install needed). Switch to Postgres in prod.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sfa
DATABASE_URL=sqlite:///./sfa.db

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

RED_AI_AFTER_DAYS=2

# Mail automation toggles
SCHEDULER_ENABLED=false
MAIL_INBOX_ENABLED=false
SMTP_ENABLED=false
MAIL_FETCH_PROTOCOL=IMAP
MAIL_INBOX_USE_SSL=true

# Inbound mailbox (IMAP or POP3 depending on MAIL_FETCH_PROTOCOL)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# SMTP (outgoing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Cron intervals (minutes)
MAIL_FETCH_INTERVAL_MINUTES=10
STATUS_CHANGE_INTERVAL_MINUTES=30
AUTO_REPLY_INTERVAL_MINUTES=15
MAIL_SEND_INTERVAL_MINUTES=5
