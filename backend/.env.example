APP_NAME=Supplier Follow-up Agent
DEBUG=true

# Local dev default: SQLite (no install needed). Switch to Postgres in prod.
# DATABASE_URL=sqlite:///./sfa.db
#
# Supabase Postgres (recommended). Use the connection pooler host (port 6543)
# if your network is IPv4-only; the direct db.<ref>.supabase.co host needs IPv6.
# Always keep ?sslmode=require for Supabase.
DATABASE_URL=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Optional: isolate this app's tables in a dedicated Postgres schema (e.g. sfa)
# when the database is shared with another app. Empty = default `public`.
DB_SCHEMA=

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate a long random secret in production: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Default admin seeded on first startup. Change the password after first login.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=System Admin

RED_AI_AFTER_DAYS=2

# Mail automation toggles
SCHEDULER_ENABLED=false
MAIL_INBOX_ENABLED=false
SMTP_ENABLED=false
MAIL_FETCH_PROTOCOL=IMAP
MAIL_INBOX_USE_SSL=true

# Inbound mailbox (IMAP or POP3 depending on MAIL_FETCH_PROTOCOL)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# SMTP (outgoing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Cron intervals (minutes)
MAIL_FETCH_INTERVAL_MINUTES=10
STATUS_CHANGE_INTERVAL_MINUTES=30
AUTO_REPLY_INTERVAL_MINUTES=15
MAIL_SEND_INTERVAL_MINUTES=5
