APP_NAME=Supplier Follow-up Agent
DEBUG=true

DATABASE_URL=sqlite:///./sfa.db
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

RED_AI_AFTER_DAYS=2

# Mail automation toggles
SCHEDULER_ENABLED=false
MAIL_INBOX_ENABLED=false
SMTP_ENABLED=false
AUTO_PO_FOLLOWUP_ENABLED=false
MAIL_FETCH_PROTOCOL=IMAP
MAIL_INBOX_USE_SSL=true

# Inbound mailbox (IMAP or POP3 depending on MAIL_FETCH_PROTOCOL)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# SMTP (outgoing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Cron intervals (minutes)
MAIL_FETCH_INTERVAL_MINUTES=10
STATUS_CHANGE_INTERVAL_MINUTES=30
AUTO_REPLY_INTERVAL_MINUTES=15
MAIL_SEND_INTERVAL_MINUTES=5

# ── LLM / AI assistant (OpenAI-compatible endpoint, e.g. NVIDIA NIM) ──────────
LLM_ENABLED=false
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
LLM_REASONING_EFFORT=
LLM_TIMEOUT_SECONDS=30
# Agentic chat does several tool-call round-trips with no fallback → longer budget.
LLM_AGENT_TIMEOUT_SECONDS=60

# ── AI feature toggles ───────────────────────────────────────────────────────
AI_AGENT_ENABLED=true          # let the Assistant call DB tools (PO/supplier/thread/RAG)
AI_AGENT_MAX_ROUNDS=4
AI_TRIAGE_ENABLED=false        # auto-classify incoming customer mails on fetch
AI_PO_FOLLOWUP_ENABLED=false   # AI-polish RED/BLACK PO follow-up bodies

# ── RAG / vector memory (pgvector — Postgres only; no-op on SQLite) ───────────
RAG_ENABLED=false              # master switch; needs Postgres + an embedding key
EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
EMBED_API_KEY=                 # leave blank to reuse LLM_API_KEY (same NVIDIA account)
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024                 # MUST match the embedding model's output dimension
EMBED_USES_INPUT_TYPE=true     # NVIDIA embedqa needs input_type (passage/query)
EMBED_TIMEOUT_SECONDS=30
RAG_TOP_K=5